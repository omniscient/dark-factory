# Dark Factory — instance configuration
#
# Copy this file to instance.env (gitignored) and fill in your values.
#
# IDENTITY VARS ARE REQUIRED for any non-MarketHawk target.
# The defaults baked into the factory image exist for MarketHawk parity only —
# they WILL NOT work for a different GitHub org, repo, or project board.
#
# How to find your project board IDs:
#   gh api graphql -f query='{ viewer { projectsV2(first:10) { nodes { id number title } } } }'
# How to find your status field + option IDs:
#   gh api graphql -f query='{ node(id:"<PROJECT_ID>") { ... on ProjectV2 { fields(first:20) { nodes { ... on ProjectV2SingleSelectField { id name options { id name } } } } } } }'

# ---------------------------------------------------------------------------
# Authentication (required — no defaults)
# ---------------------------------------------------------------------------

# GitHub token with repo + project + workflow scope.
GH_TOKEN=

# Claude authentication: use CLAUDE_CODE_OAUTH_TOKEN (Max plan) or ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Instance identity (REQUIRED for non-MarketHawk targets)
# Defaults shown are the MarketHawk values — override every line for a new target.
# ---------------------------------------------------------------------------

# GitHub org and repo that hosts your project board.
# Example (MarketHawk): FACTORY_OWNER=omniscient
FACTORY_OWNER=omniscient

# Example (MarketHawk): FACTORY_REPO=markethawk
FACTORY_REPO=markethawk

# GitHub Projects v2 node ID for your board.
# Example (MarketHawk): FACTORY_PROJECT_ID=PVT_kwHOAAFds84BWh4w
FACTORY_PROJECT_ID=PVT_kwHOAAFds84BWh4w

# GitHub Projects v2 project number (the integer shown in the board URL).
# Example (MarketHawk): FACTORY_PROJECT_NUMBER=1
FACTORY_PROJECT_NUMBER=1

# Status field node ID (PVTSSF_…) from your project board.
# Example (MarketHawk): FACTORY_STATUS_FIELD=PVTSSF_lAHOAAFds84BWh4wzhR1VaA
FACTORY_STATUS_FIELD=PVTSSF_lAHOAAFds84BWh4wzhR1VaA

# Status option IDs — the short hex IDs for each column in your board.
# Example (MarketHawk values shown for each):
FACTORY_STATUS_READY=61e4505c
FACTORY_STATUS_IN_PROGRESS=47fc9ee4
FACTORY_STATUS_IN_REVIEW=df73e18b
FACTORY_STATUS_BLOCKED=93d87b2f
FACTORY_STATUS_DONE=98236657
FACTORY_STATUS_BACKLOG=f75ad846
FACTORY_STATUS_REFINED=0c79ebe5

# Human-readable product name used in issue comments and log markers.
# Example (MarketHawk): FACTORY_PRODUCT_NAME=MarketHawk
FACTORY_PRODUCT_NAME=MarketHawk

# Absolute path inside the container where entrypoint.sh clones the target repo.
# This is the working directory used by every implementation run — independent of
# any bind-mount paths in deploy/docker-compose.yml.
# Example (MarketHawk): FACTORY_CLONE_DIR=/workspace/markethawk
FACTORY_CLONE_DIR=/workspace/markethawk

# Prefix for ephemeral factory run container names.
# Example (MarketHawk): FACTORY_RUN_PREFIX=markethawk-dark-factory-run-
FACTORY_RUN_PREFIX=markethawk-dark-factory-run-

# ---------------------------------------------------------------------------
# Scheduler tuning (optional — defaults are safe for most deployments)
# ---------------------------------------------------------------------------

# Max concurrent factory containers (default: 1).
FACTORY_WIP_LIMIT=1

# Seconds between board polls (default: 60).
POLL_INTERVAL=60

# Optional: pin the factory image version (default: latest)
# IMAGE_TAG=latest
