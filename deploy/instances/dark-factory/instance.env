# Dark Factory self-instance (P4 dogfood) — the factory develops its own repo.
# Secrets are filled on the host at deploy time, never committed.
#
# Bring up (note --env-file so FACTORY_INSTANCE reaches compose interpolation):
#   PROJECT_DIR=/path/to/dark-factory-checkout \
#   docker compose --env-file deploy/instances/dark-factory/instance.env \
#     -f deploy/docker-compose.yml up -d

GH_TOKEN=                      # fill at deploy: needs repo+project+workflow scope
CLAUDE_CODE_OAUTH_TOKEN=       # fill at deploy: Max-plan OAuth token

FACTORY_INSTANCE=dark-factory-self
FACTORY_OWNER=omniscient
FACTORY_REPO=dark-factory
FACTORY_PROJECT_ID=PVT_kwHOAAFds84BcpWz
FACTORY_PROJECT_NUMBER=2
FACTORY_STATUS_FIELD=PVTSSF_lAHOAAFds84BcpWzzhXQl6I
FACTORY_STATUS_READY=6ebab624
FACTORY_STATUS_IN_PROGRESS=a9f851ed
FACTORY_STATUS_IN_REVIEW=7cd80e96
FACTORY_STATUS_BLOCKED=8deab44b
FACTORY_STATUS_DONE=610e623d
FACTORY_STATUS_BACKLOG=d877a5b3
FACTORY_STATUS_REFINED=3b647822
FACTORY_PRODUCT_NAME=Dark Factory
FACTORY_CLONE_DIR=/workspace/dark-factory
FACTORY_RUN_PREFIX=dark-factory-self-run-

FACTORY_WIP_LIMIT=1
POLL_INTERVAL=60
# IMAGE_TAG=latest             # pin a digest for deterministic rollback
